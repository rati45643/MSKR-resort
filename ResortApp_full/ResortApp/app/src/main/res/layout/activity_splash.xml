<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/bg_welcome"
    android:padding="32dp">

    <!-- Resort logo -->
    <TextView
        android:id="@+id/tvLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🌴"
        android:textSize="80sp"
        android:layout_marginBottom="24dp" />

    <!-- Resort name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MSKR Resort"
        android:textSize="28sp"
        android:textColor="#FFFFFF"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.05"
        android:layout_marginBottom="8dp" />

    <!-- Tag line -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your paradise awaits"
        android:textSize="16sp"
        android:textColor="#B9F6CA"
        android:fontFamily="sans-serif-light"
        android:layout_marginBottom="24dp" />

    <!-- App description -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Book luxury rooms, order delicious food, and enjoy premium resort services with a seamless digital experience."
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="40dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp" />

    <!-- Get Started button -->
    <Button
        android:id="@+id/btnGetStarted"
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:text="Get Started"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#FFFFFF"
        android:textColor="@color/colorPrimary" />

</LinearLayout>